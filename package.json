{
  "name": "x-twitter-scraper",
  "version": "0.6.1",
  "description": "Xquik TypeScript SDK & agent Skills for X/Twitter data, automation, MCP & webhooks. Not affiliated with X Corp.",
  "author": "Xquik <support@xquik.com>",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "commonjs",
  "homepage": "https://docs.xquik.com/sdks/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xquik-dev/x-twitter-scraper-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/Xquik-dev/x-twitter-scraper-typescript/issues"
  },
  "keywords": [
    "x-api",
    "twitter-api",
    "twitter-scraper",
    "x-twitter-scraper",
    "xquik",
    "pi-package",
    "typescript-sdk",
    "nodejs",
    "api-client",
    "webhooks",
    "monitoring",
    "social-media-api"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "image": "https://raw.githubusercontent.com/Xquik-dev/x-twitter-scraper-typescript/main/assets/pi-package.png"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.15.1",
  "files": [
    "**/*"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "./scripts/test",
    "build": "./scripts/build",
    "check:reproducible": "./scripts/check-reproducible",
    "prepublishOnly": "echo 'to publish, run pnpm build && (cd dist; pnpm publish)' && exit 1",
    "format": "./scripts/format",
    "prepare": "if ./scripts/utils/check-is-in-git-install.sh; then ./scripts/build && ./scripts/utils/git-swap.sh; fi",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "./scripts/lint",
    "fix": "./scripts/format"
  },
  "dependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unused-imports": "4.4.1",
    "jest": "30.4.2",
    "prettier": "3.1.1",
    "publint": "0.3.21",
    "ts-node": "10.9.2",
    "tsc-multi": "https://github.com/stainless-api/tsc-multi/releases/download/v1.1.11/tsc-multi.tgz",
    "tsconfig-paths": "4.2.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*.mjs": {
      "default": "./dist/*.mjs"
    },
    "./*.js": {
      "default": "./dist/*.js"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  }
}
