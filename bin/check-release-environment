#!/usr/bin/env bash

set -euo pipefail

errors=()
workflow=".github/workflows/publish-npm.yml"

if [[ "$(node -p "require('./package.json').name")" != "x-twitter-scraper" ]]; then
  errors+=("package.json must identify the TypeScript SDK as x-twitter-scraper")
fi

for required in \
  "environment: npm" \
  "id-token: write" \
  "EXPECTED_PACKAGE_NAME: x-twitter-scraper" \
  "bash ./bin/publish-npm"; do
  if ! grep -Fq "$required" "$workflow"; then
    errors+=("publish-npm.yml is missing: ${required}")
  fi
done

for forbidden in "NPM_TOKEN" "NODE_AUTH_TOKEN" "workflow_dispatch"; do
  if grep -Fq "$forbidden" "$workflow" bin/publish-npm; then
    errors+=("release path must not contain: ${forbidden}")
  fi
done

if (( ${#errors[@]} > 0 )); then
  printf 'Release environment errors:\n' >&2
  printf ' - %s\n' "${errors[@]}" >&2
  exit 1
fi

printf 'Release environment is configured for tokenless trusted publishing.\n'
